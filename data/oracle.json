[
  {
    "id": 1,
    "verse": "雲開見日，久雨初晴。",
    "meaning": "困局漸解，宜靜待轉機，不可躁進。"
  },
  {
    "id": 2,
    "verse": "行路半途，風波未定。",
    "meaning": "局勢仍變，需觀察形勢再行動。"
  },
  {
    "id": 3,
    "verse": "月隱東山，光未全明。",
    "meaning": "時機未至，宜守不宜攻。"
  },
  {
    "id": 4,
    "verse": "舟過險灘，慎行無咎。",
    "meaning": "雖有風險，但謹慎可保無事。"
  },
  {
    "id": 5,
    "verse": "春雷初動，萬物將醒。",
    "meaning": "新局將開，機會正在醞釀。"
  },
  {
    "id": 6,
    "verse": "孤雲出岫，自在無拘。",
    "meaning": "宜順勢而為，不宜強求控制。"
  },
  {
    "id": 7,
    "verse": "霧中觀花，真假難分。",
    "meaning": "資訊不清，需防誤判。"
  },
  {
    "id": 8,
    "verse": "古木逢春，再生新枝。",
    "meaning": "舊事重啟，有翻盤機會。"
  },
  {
    "id": 9,
    "verse": "水流無定，順勢則安。",
    "meaning": "環境變動，順勢比對抗更重要。"
  },
  {
    "id": 10,
    "verse": "夜行見火，前路可循。",
    "meaning": "雖處黑暗，但已有方向線索。"
  },
  {
    "id": 11,
    "verse": "高山仰止，力不可及。",
    "meaning": "目標過高，需調整期待。"
  },
  {
    "id": 12,
    "verse": "風動林響，心隨境轉。",
    "meaning": "情緒易受影響，需保持穩定。"
  },
  {
    "id": 13,
    "verse": "雨過天青，萬象更新。",
    "meaning": "困難解除，進入新階段。"
  },
  {
    "id": 14,
    "verse": "石中藏玉，待人發掘。",
    "meaning": "潛力尚未被看見，需要時間。"
  },
  {
    "id": 15,
    "verse": "孤舟獨行，心定則安。",
    "meaning": "獨立行動，內心穩定最重要。"
  },
  {
    "id": 16,
    "verse": "雲深不知處，莫問前程。",
    "meaning": "未來不明，專注當下即可。"
  },
  {
    "id": 17,
    "verse": "寒梅傲雪，靜待春來。",
    "meaning": "逆境中堅持，終有回報。"
  },
  {
    "id": 18,
    "verse": "流水穿石，非一日功。",
    "meaning": "長期累積，方見成果。"
  },
  {
    "id": 19,
    "verse": "明鏡未磨，難照真形。",
    "meaning": "認知尚未清晰，需自我整理。"
  },
  {
    "id": 20,
    "verse": "雷動九天，勢不可擋。",
    "meaning": "變局強烈，順勢者勝。"
  },
  {
    "id": 21,
    "verse": "舊夢重現，因緣再起。",
    "meaning": "過去事件可能再度出現。"
  },
  {
    "id": 22,
    "verse": "孤月照影，內觀自省。",
    "meaning": "適合反思，不宜外求結果。"
  },
  {
    "id": 23,
    "verse": "路轉峰迴，別有洞天。",
    "meaning": "轉折之後有新機會。"
  },
  {
    "id": 24,
    "verse": "風止雲散，萬事初定。",
    "meaning": "局勢穩定，可開始行動。"
  }
]
